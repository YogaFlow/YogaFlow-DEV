# Supabase – nur für lokale Entwicklung mit DEV-Datenbank verwenden!
# Kopiere diese Datei als .env und trage die Werte deines DEV-Projekts ein.
# .env NIEMALS committen – sie steht in .gitignore.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Basis-Domain für Tenant-Subdomain-Routing (z.B. omlify.de)
# In Cloudflare Pages als Env-Var setzen: VITE_APP_BASE_DOMAIN=omlify.de
VITE_APP_BASE_DOMAIN=
